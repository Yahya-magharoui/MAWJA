generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String?   // <-- AJOUT
  createdAt     DateTime @default(now())
  mood          MoodEntry[]
}

model MoodEntry {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  state     String   // hypo | window | hyper
  value     Int
  context   String?
  timestamp DateTime @default(now())
}
